# ============================================================
# Course materials
# Keep the useful generated docs, but do not commit large PDFs,
# slides, or potentially copyrighted course content.
# ============================================================
content/**/*.pdf
content/**/*.ppt
content/**/*.pptx
content/**/*.key
content/**/*.pages

# Optional: ignore extracted course text if it is generated locally
content/extracted-text/

# ============================================================
# AI / local agent files
# ============================================================
.codex/
.cursor/
.claude/
.agent/
tmp/
scratch/
notes-private/

# Keep shared project instructions if you create them
!.cursor/rules/
!.claude/commands/

